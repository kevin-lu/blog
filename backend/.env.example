# Flask Configuration
FLASK_APP=app/__init__.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-in-production

# Database
# MySQL 8 Configuration
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/blog_db?charset=utf8mb4

# SQLite Configuration (for local development)
# DATABASE_URL=sqlite:///blog.db

# JWT Configuration
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=604800
JWT_TOKEN_LOCATION=["headers", "cookies"]
JWT_COOKIE_SECURE=false
JWT_COOKIE_CSRF_PROTECT=true

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_SUPPORTS_CREDENTIALS=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# File Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,txt

# Rate Limiting
RATELIMIT_DEFAULT=100 per hour
RATELIMIT_STORAGE_URL=memory://

# Swagger
SWAGGER_UI_DOC_EXPAND=true

# AI Rewrite
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_API_HOST=https://api.minimaxi.com/v1/chat/completions
MINIMAX_REQUEST_TIMEOUT=300
MINIMAX_MAX_RETRIES=2
AI_SOURCE_MAX_CHARS=12000
AI_REWRITE_RATE_LIMIT=30 per minute

# RSS Crawler
CRAWLER_TIMEOUT=30
CRAWLER_RETRY_TIMES=3
CRAWLER_RETRY_DELAY=5

# AI Queue
AI_QUEUE_BATCH_SIZE=1
AI_QUEUE_DELAY_BETWEEN_TASKS=5
AI_QUEUE_MAX_RETRIES=2
AI_QUEUE_TIMEOUT=60

# Scheduler
SCHEDULER_TIMEZONE=Asia/Shanghai
SCHEDULER_MISFIRE_GRACE_TIME=3600

# Alert Service
DINGTALK_WEBHOOK=
WECHAT_WORK_WEBHOOK=
ALERT_QUEUE_THRESHOLD=10
ENABLE_DAILY_REPORT=false
